# Credenciales del proyecto de Supabase (Dashboard → Settings → API).
# Copiar este archivo a .env.local y completar los valores reales.
# El prefijo VITE_ es obligatorio: Vite solo expone al cliente las variables
# que lo llevan. La anon key es pública por diseño (RLS protege los datos).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
